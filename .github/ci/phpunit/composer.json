{
  "require"           : {
    "php" : ">=8.4"
  },
  "require-dev"       : {
    "valkyrja/phpunit" : "^26.1.0"
  },
  "scripts"           : {
    "check"    : "vendor/bin/phpunit --no-coverage --display-all-issues",
    "coverage" : "php -d xdebug.mode=coverage -d memory_limit=-1 vendor/bin/phpunit --coverage-text --stderr"
  },
  "minimum-stability" : "dev",
  "prefer-stable"     : true
}
