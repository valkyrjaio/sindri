{
  "require"           : {
    "php" : ">=8.4"
  },
  "require-dev"       : {
    "valkyrja/phpcsfixer" : "^26.1.1"
  },
  "scripts"           : {
    "fix"   : "vendor/bin/php-cs-fixer fix --config=.php_cs.dist.php",
    "check" : "vendor/bin/php-cs-fixer fix --config=.php_cs.dist.php --dry-run"
  },
  "minimum-stability" : "dev",
  "prefer-stable"     : true
}
